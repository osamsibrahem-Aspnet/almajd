{
  "Logging": {
    "LogLevel": {
      "Default": "Information",
      "Microsoft.AspNetCore": "Warning"
    }
  },
  "AllowedHosts": "*",
  "ConnectionStrings": {
    "DefaultConnection": "Server=localhost,1434;Database=Almajd;User Id=sa;Password=<set-via-user-secrets>;TrustServerCertificate=True;Encrypt=False"
  },
  "JWT": {
    "Key": "<set-via-user-secrets — at least 32-char base64 random>",
    "Issuer": "Almajd.Api",
    "Audience": "Almajd.Client",
    "DurationInDays": 3
  },
  "DefaultAdmin": {
    "Email": "admin@almajd.local",
    "Password": "<set-via-user-secrets>"
  },
  "MailSettings": {
    "From": "no-reply@your-domain",
    "SmtpServer": "smtp.gmail.com",
    "Port": 587,
    "Username": "<smtp-user>",
    "Password": "<smtp-password>"
  },
  "ApiUrl": "https://api.your-domain/",
  "ClientUrl": "https://app.your-domain/",
  "Pricing": {
    "DefaultVatPct": 14
  },
  "Otp": {
    "CodeLength": 6,
    "ExpiryMinutes": 5,
    "MaxAttempts": 5,
    "HashKey": "<set-via-user-secrets — at least 32-char random for HMAC-SHA256>"
  }
}
